{
  "name": "@pruett/fleet",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fleet": "bin/fleet.ts"
  },
  "files": ["bin/", "src/", "client/dist/"],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": ["client"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --watch src/main.ts",
    "dev:client": "bun run --filter @fleet/client dev",
    "start": "FLEET_STATIC_DIR=client/dist bun run src/main.ts",
    "build": "bun run --filter @fleet/client build",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit && bun run --filter @fleet/client typecheck"
  },
  "dependencies": {
    "hono": "^4.7.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
