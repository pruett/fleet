{
  "name": "@pruett/fleet",
  "version": "0.2.1",
  "description": "A companion dashboard for your AI coding agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fleet": "bin/fleet.ts"
  },
  "files": ["bin/", "src/", "shared/", "client/dist/"],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": ["client", "shared"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --watch src/main.ts",
    "dev:client": "bun run --filter @fleet/client dev",
    "start": "FLEET_STATIC_DIR=client/dist bun run src/main.ts",
    "build": "bun run --filter @fleet/client build",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit && bun run --filter '*' typecheck"
  },
  "dependencies": {
    "@fleet/shared": "workspace:*",
    "hono": "^4.7.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "dashboard",
    "monitoring",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pruett/fleet.git"
  },
  "homepage": "https://github.com/pruett/fleet#readme"
}
